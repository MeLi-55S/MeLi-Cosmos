# =============================================================================
# MeLi Cosmos v2.0 环境变量
# 复制此文件为 .env 后按需修改
# =============================================================================

# Django 核心
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=替换为随机字符串-生产环境务必修改
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# 数据库 (默认使用 SQLite，无需修改以下两行)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# =============================================================================
# 切换到 PostgreSQL 时的额外配置（取消注释并填写）
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=my_cosmos
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=my_cosmos_user
# DB_PASSWORD=your_password
# =============================================================================
